{
  "compilerOptions": {
    "target": "es5",
    "lib": ["es5", "dom"],
    "allowJs": true,
    "checkJs": true,
    "types": ["cypress", "node"],
    "baseUrl": "./cypress",
    "ignoreDeprecations": "6.0"
  },
  "include": ["cypress/**/*.js", "cypress/**/*.ts", "cypress/**/*.d.ts", "cypress.config.js"]
}
